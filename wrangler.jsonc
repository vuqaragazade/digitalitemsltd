{
  "name": "digitalitemsltd",
  "main": "frontend-worker.js",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/sitemap.xml", "/robots.txt"]
  }
}
